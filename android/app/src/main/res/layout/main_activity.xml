<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF8F8">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:paddingTop="17dp"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="8dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtLogo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PEAKSNEAKER"
            android:textStyle="bold"
            android:textSize="28sp"
            android:fontFamily="@font/plusjakartasans_extrabold"
            android:textColor="#396477"/>

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="20dp">

            <ImageView
                android:id="@+id/imgNotification"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/notifications_64dp"/>

            <TextView
                android:id="@+id/txtNotificationBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end|top"
                android:background="@drawable/bg_badge_red"
                android:gravity="center"
                android:text="2"
                android:textColor="@android:color/white"
                android:textSize="8sp"
                android:textStyle="bold"/>

        </FrameLayout>

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="20dp">

            <ImageView
                android:id="@+id/imgCart"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/shopping_bag_64dp"/>

            <TextView
                android:id="@+id/txtCartNumberItem"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end|top"
                android:background="@drawable/bg_badge_red"
                android:gravity="center"
                android:text="2"
                android:textColor="@android:color/white"
                android:textSize="8sp"
                android:textStyle="bold"/>

        </FrameLayout>

    </LinearLayout>


    <!-- VIEWPAGER -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- BOTTOM BAR -->

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="105dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_bar"
        android:elevation="16dp"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="40dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Home -->

        <LinearLayout
            android:id="@+id/menuHome"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/home_64dp"/>

            <TextView
                android:id="@+id/txtHome"
                android:text="Trang chủ"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plusjakartasans_extrabold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Store -->
        <LinearLayout
            android:id="@+id/menuStore"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <ImageView
                android:id="@+id/iconStore"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/storefront_64dp"/>

            <TextView
                android:id="@+id/txtStore"
                android:text="Cửa hàng"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plusjakartasans_extrabold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Order -->
        <LinearLayout
            android:id="@+id/menuOrder"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <ImageView
                android:id="@+id/iconOrder"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/receipt_long_64dp"/>

            <TextView
                android:id="@+id/txtOrder"
                android:text="Đơn hàng"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plusjakartasans_extrabold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/menuProfile"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <ImageView
                android:id="@+id/iconProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/person_64dp"/>

            <TextView
                android:id="@+id/txtProfile"
                android:text="Hồ sơ"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plusjakartasans_extrabold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
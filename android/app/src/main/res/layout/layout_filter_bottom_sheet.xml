<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingTop="12dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#D1D1D1" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Bộ lọc tìm kiếm"
            android:textColor="#1C1B1B"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_close"
            app:tint="#1C1B1B" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Giới tính"
                android:textColor="#1C1B1B"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipGenderMale"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_selected"
                    android:gravity="center"
                    android:text="Nam"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipGenderFemale"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="Nữ"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipGenderUnisex"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="Unisex"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Khoảng giá"
                android:textColor="#1C1B1B"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipPriceUnder2m"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="Dưới 2 triệu"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipPrice2to4m"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="2 - 4 triệu"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipPriceOver4m"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="Trên 4 triệu"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Sắp xếp theo giá"
                android:textColor="#1C1B1B"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipSortLowToHigh"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="Giá: Thấp đến Cao"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipSortHighToLow"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="Giá: Cao đến Thấp"
                    android:textColor="#1C1B1B"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Kích cỡ"
                android:textColor="#1C1B1B"
                android:textSize="15sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:columnCount="4"
                android:rowCount="2">

                <TextView
                    android:id="@+id/chipSize36"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_chip_selected"
                    android:gravity="center"
                    android:text="36"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/chipSize37"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="37"
                    android:textColor="#1C1B1B" />

                <TextView
                    android:id="@+id/chipSize38"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="38"
                    android:textColor="#1C1B1B" />

                <TextView
                    android:id="@+id/chipSize39"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="39"
                    android:textColor="#1C1B1B" />

                <TextView
                    android:id="@+id/chipSize40"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="40"
                    android:textColor="#1C1B1B" />

                <TextView
                    android:id="@+id/chipSize41"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="41"
                    android:textColor="#1C1B1B" />

                <TextView
                    android:id="@+id/chipSize42"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="42"
                    android:textColor="#1C1B1B" />

                <TextView
                    android:id="@+id/chipSize43"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:text="43"
                    android:textColor="#1C1B1B" />
            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <Button
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_unselected"
            android:text="Thiết lập lại"
            android:textAllCaps="false"
            android:textColor="#1C1B1B"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnApply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_filter"
            android:text="Áp dụng"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>
</LinearLayout>
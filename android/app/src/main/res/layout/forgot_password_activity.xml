<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFCF8"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/imgForgot"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="28dp"
            android:scaleType="centerCrop"
            android:src="@drawable/forgot_password_image"
            android:background="@drawable/bg_password_image"
            android:clipToOutline="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quên mật khẩu"
            android:textStyle="bold"
            android:textSize="24sp"
            android:letterSpacing="-0.01"
            android:textColor="#1C1B1B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Nhập email của bạn để đặt lại mật khẩu."
            android:textColor="#444748"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginStart="4dp"
            android:text="Email của bạn"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#444748"
            android:letterSpacing="0.02" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_selector"
                android:hint="example@email.com"
                android:textColorHint="#C4C7C8"
                android:textColor="#1C1B1B"
                android:textSize="14sp"
                android:paddingStart="52dp"
                android:paddingEnd="16dp"
                android:inputType="textEmailAddress" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="14dp"
                android:src="@drawable/ic_mail"
                android:contentDescription="Email icon"
                app:tint="#747878" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_primary_button"
            android:text="Xác nhận email"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="28dp"
            app:strokeWidth="0dp"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="end"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                app:tint="#396477" />

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Quay lại đăng nhập"
                android:textColor="#396477"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
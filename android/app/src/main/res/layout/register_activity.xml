<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFCF8"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:layout_marginBottom="30dp">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tạo tài khoản mới"
            android:textStyle="bold"
            android:textSize="38sp"
            android:letterSpacing="-0.02"
            android:textColor="#1C1B1B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Trở thành thành viên của PeakSneaker ngay hôm nay"
            android:textColor="#444748"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginStart="4dp"
            android:text="Họ"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#444748"
            android:letterSpacing="0.02" />

        <EditText
            android:id="@+id/edtLastName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_selector"
            android:hint="Nguyễn"
            android:textColorHint="#C4C7C8"
            android:textColor="#1C1B1B"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="4dp"
            android:text="Tên"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#444748"
            android:letterSpacing="0.02" />

        <EditText
            android:id="@+id/edtFirstName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_selector"
            android:hint="Văn A"
            android:textColorHint="#C4C7C8"
            android:textColor="#1C1B1B"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="4dp"
            android:text="Email"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#444748"
            android:letterSpacing="0.02" />

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_selector"
            android:hint="example@email.com"
            android:textColorHint="#C4C7C8"
            android:textColor="#1C1B1B"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="4dp"
            android:text="Số điện thoại"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#444748"
            android:letterSpacing="0.02" />

        <EditText
            android:id="@+id/edtPhone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_selector"
            android:hint="09xx xxx xxx"
            android:textColorHint="#C4C7C8"
            android:textColor="#1C1B1B"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:inputType="phone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="4dp"
            android:text="Mật khẩu"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#444748"
            android:letterSpacing="0.02" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_selector"
                android:hint="••••••••"
                android:textColorHint="#C4C7C8"
                android:textColor="#1C1B1B"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="52dp"
                android:inputType="textPassword" />

            <ImageButton
                android:id="@+id/btnTogglePassword"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_visibility_off"
                android:contentDescription="Toggle password"
                app:tint="#444748" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="4dp"
            android:text="Xác nhận mật khẩu"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#444748"
            android:letterSpacing="0.02" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_selector"
                android:hint="••••••••"
                android:textColorHint="#C4C7C8"
                android:textColor="#1C1B1B"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="52dp"
                android:inputType="textPassword" />

            <ImageButton
                android:id="@+id/btnToggleConfirmPassword"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_visibility_off"
                android:contentDescription="Toggle confirm password"
                app:tint="#444748" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="top">

            <CheckBox
                android:id="@+id/cbTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:buttonTint="#396477" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Tôi đồng ý với Điều khoản và Chính sách bảo mật của PeakSneaker."
                android:textColor="#444748"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="20dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_primary_button"
            android:text="Tạo tài khoản"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="28dp"
            app:strokeWidth="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E5E2E1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:text="HOẶC ĐĂNG KÝ BẰNG"
                android:textColor="#444748"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E5E2E1" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_google"
            android:text="Google"
            android:textAllCaps="false"
            android:textColor="#1E4C5F"
            android:textSize="15sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_google"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@null"
            app:backgroundTint="@null"
            app:strokeWidth="0dp"
            app:cornerRadius="28dp" />

        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="Đã có tài khoản? Đăng nhập"
            android:textColor="#396477"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>